# =============================================================================
# StudyBot 環境変数設定
# =============================================================================
# このファイルを .env にコピーして値を設定してください:
#   cp .env.example .env
#
# 必須マークのある変数は設定しないと起動しません。
# =============================================================================

# ========== Discord Bot (必須) ==========
# Discord Developer Portal で取得: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Bot管理者のDiscord User ID (管理者コマンド用、任意)
BOT_OWNER_ID=your_user_id

# ========== Database ==========
# PostgreSQL 接続URL (docker-compose使用時はこのままでOK)
DATABASE_URL=postgresql://studybot:studybot_dev@localhost:5432/studybot

# PostgreSQL パスワード (docker-compose のpostgresサービス用)
POSTGRES_PASSWORD=studybot_dev

# DB接続プール設定
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30

# ========== OpenAI (AI機能を使う場合) ==========
# OpenAI API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 使用モデル (コスト最適化済み)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# AI機能の1ユーザーあたり1日の利用上限
AI_DAILY_LIMIT=10

# ========== API (FastAPI) ==========
# JWT署名キー (本番環境では必ずランダムな長い文字列に変更)
API_SECRET_KEY=change-me-in-production

# Discord OAuth2 設定 (Web/モバイルアプリ連携時に必要)
# Discord Developer Portal → OAuth2 で取得
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback

# APIとWebアプリのURL
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000

# ========== Redis ==========
# Redis 接続URL (docker-compose使用時はこのままでOK)
REDIS_URL=redis://localhost:6379/0

# ========== Logging ==========
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
