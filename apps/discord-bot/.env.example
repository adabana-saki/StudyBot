# =============================================================================
# StudyBot Discord Bot 環境変数
# =============================================================================
# このファイルを .env にコピーして値を設定してください:
#   cp .env.example .env
# =============================================================================

# ========== 必須 ==========
# Discord Bot トークン (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# PostgreSQL 接続URL
DATABASE_URL=postgresql://studybot:studybot_dev@localhost:5432/studybot

# ========== AI機能 (任意) ==========
# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# 使用モデル
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# 1ユーザーあたり1日のAI利用上限
AI_DAILY_LIMIT=10

# ========== その他 (任意) ==========
# Bot管理者のDiscord User ID
BOT_OWNER_ID=your_user_id

# ギルド限定コマンド同期 (設定するとそのサーバー専用になり即時反映)
GUILD_ID=

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ========== DB接続プール ==========
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=30

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== Docker Compose用 ==========
POSTGRES_PASSWORD=studybot_dev

# ========== API/Web連携 (任意) ==========
API_SECRET_KEY=change-me-in-production
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
